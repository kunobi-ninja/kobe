{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      },
      "required": ["repository"]
    },
    "replicas": { "type": "integer", "minimum": 1 },
    "logLevel": { "type": "string" },
    "operatorNamespace": { "type": "string", "minLength": 1 },
    "kobeSync": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string" }
          },
          "required": ["repository"]
        }
      }
    },
    "postgres": {
      "type": "object",
      "properties": {
        "url": { "type": "string" }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "interval": { "type": "string" },
        "labels": { "type": "object" }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": ["integer", "string"] },
        "maxUnavailable": { "type": ["integer", "string"] }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "apiServerCIDR": { "type": "string" },
        "egressCIDRs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "etcd": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "hostReaper": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" }
          }
        },
        "leaseRoot": { "type": "string" },
        "reconcileInterval": { "type": "string" },
        "mtimeSkip": { "type": "string" },
        "dryRun": { "type": "boolean" },
        "disable": { "type": "boolean" },
        "namespacePsaLabels": { "type": "boolean" },
        "tolerations": {
          "type": "array",
          "items": { "type": "object" }
        },
        "resources": {
          "type": "object",
          "properties": {
            "limits": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string" },
                "memory": { "type": "string" }
              }
            },
            "requests": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string" },
                "memory": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
